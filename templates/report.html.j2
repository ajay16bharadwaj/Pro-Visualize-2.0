<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pro-Visualize Report</title>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
      color: #1a1a2e;
      background: #f4f6f9;
      line-height: 1.5;
    }
    header { margin-bottom: 2rem; }
    h1 { font-size: 1.9rem; margin: 0 0 0.25rem; border-bottom: 2px solid #4a90e2; padding-bottom: 0.5rem; }
    h2 { font-size: 1.15rem; color: #2c3e50; margin: 0 0 1rem; }
    .meta { color: #666; font-size: 0.9rem; margin-top: 0.25rem; }
    section.report-item {
      background: #fff;
      border-radius: 8px;
      padding: 1.5rem;
      margin: 1.5rem 0;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    }
    img { max-width: 100%; height: auto; border-radius: 4px; display: block; }
    details { margin-top: 0.75rem; }
    summary { cursor: pointer; color: #4a90e2; font-size: 0.875rem; user-select: none; }
    summary:hover { color: #2a70c2; }
    .params-table { width: 100%; border-collapse: collapse; font-size: 0.825rem; margin-top: 0.5rem; }
    .params-table td { border: 1px solid #e0e6ed; padding: 0.35rem 0.6rem; vertical-align: top; }
    .params-table td:first-child { background: #f0f4f8; font-weight: 600; width: 30%; }
    table.report-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    table.report-table th { background: #f0f4f8; font-weight: 600; text-align: left; padding: 0.4rem 0.6rem; border: 1px solid #dde3ea; }
    table.report-table td { border: 1px solid #dde3ea; padding: 0.35rem 0.6rem; }
    table.report-table tr:nth-child(even) td { background: #f8fafc; }
    .notes {
      background: #fffde7;
      border-left: 3px solid #f9a825;
      padding: 0.5rem 0.75rem;
      margin-top: 0.75rem;
      border-radius: 0 4px 4px 0;
      font-size: 0.9rem;
      white-space: pre-wrap;
    }
    .empty-fig { color: #999; font-style: italic; padding: 1rem; text-align: center; border: 1px dashed #ccc; border-radius: 4px; }
    footer { margin-top: 3rem; text-align: center; color: #aaa; font-size: 0.8rem; padding-top: 1rem; border-top: 1px solid #e0e0e0; }
  </style>
</head>
<body>
  <header>
    <h1>Pro-Visualize Report</h1>
    <p class="meta">Generated {{ generated_at }} · {{ app_version }}</p>
  </header>

  {% for item in items %}
  <section class="report-item" id="{{ item.key | e }}">
    <h2>{{ item.title }}</h2>

    {% if item.kind == "plotly" %}
      {% if item.fig_html %}
        {{ item.fig_html | safe }}
      {% else %}
        <p class="empty-fig">Interactive figure could not be rendered.</p>
      {% endif %}

    {% elif item.kind == "matplotlib_png" %}
      {% if item.fig_b64 %}
        <img src="data:image/png;base64,{{ item.fig_b64 }}" alt="{{ item.title | e }}">
      {% else %}
        <p class="empty-fig">Figure could not be rendered.</p>
      {% endif %}

    {% elif item.kind == "table" %}
      {% if item.table_html %}
        {{ item.table_html | safe }}
      {% else %}
        <p class="empty-fig">Table could not be rendered.</p>
      {% endif %}

    {% elif item.kind == "section" %}
      <p>{{ item.notes }}</p>

    {% endif %}

    {% if item.params %}
    <details>
      <summary>Parameters</summary>
      <table class="params-table">
        {% for k, v in item.params.items() %}
        <tr><td>{{ k }}</td><td>{{ v }}</td></tr>
        {% endfor %}
      </table>
    </details>
    {% endif %}

    {% if item.notes and item.kind != "section" %}
    <div class="notes">{{ item.notes }}</div>
    {% endif %}
  </section>
  {% endfor %}

  <footer>Generated by {{ app_version }} · {{ generated_at }}</footer>
</body>
</html>
